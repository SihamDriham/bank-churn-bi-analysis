<attr name="transform"><![CDATA[//#CTL2

// Transforms input record into output record.
function integer transform() {
	$out.0.CustomerId = $in.1.CustomerId;
	$out.0.GeographyId = $in.1.GeographyId;
	$out.0.DateId = $in.1.DateId;
	$out.0.CreditScore = $in.0.CreditScore;
	$out.0.Tenure = $in.0.Tenure;
	$out.0.Balance = $in.0.Balance;
	$out.0.NumOfProducts = $in.0.NumOfProducts;
	$out.0.Exited = $in.0.Exited;

	return ALL;
}

