<attr name="sqlQuery"><![CDATA[SELECT 

	(SELECT CustomerId FROM Customer WHERE CustomerId = ?) AS CustomerId,

	(SELECT GeographyId FROM geography WHERE Country= ?) AS GeographyId,

	(SELECT id FROM date WHERE date = STR_TO_DATE(?,  '%d-%m-%Y')) AS DateId;]]></attr>
